{
   "action": {
      "default_icon": "label/icons/plugin/icon.png"
   },
   "background": {
      "service_worker": "background.js"
   },
   "content_scripts": [ {
      "css": [ "label/css/wabacrm.css", "content/assets/css/style.css", "content.css" ],
      "js": [ "content/index.js" ],
      "matches": [ "https://web.whatsapp.com/*" ]
   } ],
   "description": "CRM EFSM: Toda conversa é uma oportunidade. Use nosso CRM para transformar leads e vendas",
   "externally_connectable": {
      "matches": [ "https://user.xxyz.be/*", "https://dev.watools.com.br/*" ]
   },
   "icons": {
      "128": "label/icons/plugin/icon.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "CRM EFSM: Sua principal ferramenta para vendas!",
   "permissions": [ "unlimitedStorage", "storage", "alarms", "tabs" ],
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "4.3.30",
   "web_accessible_resources": [ {
      "matches": [ "https://web.whatsapp.com/*" ],
      "resources": [ "*.js", "*.css", "*.png", "*.mp3", ".ttf", "label/*.json", "label/*.png" ]
   } ]
}
